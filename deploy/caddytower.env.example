# Controller image for CaddyTower itself. This is NOT one of your app images.
CADDYTOWER_IMAGE=ghcr.io/knopkem/caddytower:latest
CADDYTOWER_HTTP_ADDR=:8080
# Public URL users and webhooks use to reach the admin UI. Keep this local value
# for the first setup over an SSH tunnel, then change it to the final HTTPS URL
# before exposing CaddyTower publicly.
CADDYTOWER_PUBLIC_BASE_URL=http://127.0.0.1:8080
CADDYTOWER_DATA_DIR=/data
# Leave this alone when using the bundled shared-caddy container.
CADDYTOWER_CADDY_ADMIN_URL=http://shared-caddy:2019
# Base domain used for generated app subdomains such as app.example.com.
CADDYTOWER_ROOT_DOMAIN=
# Generated automatically by the bootstrap script on first run. Keep it stable:
# it encrypts project env values, TOTP secrets, database credentials, and API
# tokens at rest.
CADDYTOWER_MASTER_KEY=REPLACE_WITH_GENERATED_KEY
# Optional GitHub App integration for repo import. All four values must be set
# together. Mount the private key PEM into the container and point
# CADDYTOWER_GITHUB_APP_PRIVATE_KEY_PATH at the in-container path.
CADDYTOWER_GITHUB_APP_ID=
CADDYTOWER_GITHUB_APP_SLUG=
CADDYTOWER_GITHUB_APP_PRIVATE_KEY_PATH=
CADDYTOWER_GITHUB_WEBHOOK_SECRET=
# Optional for GitHub Enterprise Server or a GitHub-compatible deployment.
CADDYTOWER_GITHUB_API_BASE_URL=https://api.github.com
CADDYTOWER_GITHUB_WEB_BASE_URL=https://github.com
# Optional backup settings.
CADDYTOWER_BACKUPS_ENABLED=false
CADDYTOWER_BACKUPS_RETENTION_DAYS=14
CADDYTOWER_BACKUPS_SCHEDULE_UTC=02:30
CADDYTOWER_BACKUPS_INCLUDE_ENGINE_DUMPS=true
# Optional VPS warning thresholds and polling settings.
CADDYTOWER_VPS_WARNINGS_ENABLED=true
CADDYTOWER_VPS_RAM_FREE_WARN_PERCENT=15
CADDYTOWER_VPS_DISK_FREE_WARN_PERCENT=15
CADDYTOWER_VPS_WARNING_CHECK_MINUTES=15
CADDYTOWER_VPS_WARNING_COOLDOWN_MINUTES=360
# Optional email alerts for low RAM/disk warnings.
CADDYTOWER_SMTP_HOST=
CADDYTOWER_SMTP_PORT=587
CADDYTOWER_SMTP_USERNAME=
CADDYTOWER_SMTP_PASSWORD=
CADDYTOWER_SMTP_FROM=
CADDYTOWER_SMTP_TO=
